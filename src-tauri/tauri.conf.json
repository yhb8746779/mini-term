{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Mini-Term",
  "version": "0.2.41",
  "identifier": "com.tauri-app.tauri-app",
  "build": {
    "beforeDevCommand": "node src-tauri/scripts/prepare-sidecar.mjs debug && npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build && node src-tauri/scripts/prepare-sidecar.mjs release",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Mini-Term",
        "width": 800,
        "height": 600,
        "dragDropEnabled": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "externalBin": ["binaries/miniterm-hook"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "minimumSystemVersion": "10.15"
    }
  }
}
